{
  "manifest_version": 3,
  "name": "TokenCave",
  "version": "1.0.0",
  "description": "Token counter, usage tracker, cache timer, and caveman compression mode for claude.ai — all in one cave.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "action": {
    "default_title": "TokenCave",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "css": ["src/styles.css"],
      "js": [
        "src/content/constants.js",
        "src/content/bridge-client.js",
        "src/vendor/o200k_base.js",
        "src/content/tokens.js",
        "src/content/caveman.js",
        "src/content/ui.js",
        "src/content/main.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected/bridge.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{tokencave-extension-id}",
      "strict_min_version": "109.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
